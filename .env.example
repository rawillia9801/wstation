# Lorex camera feed
# Browsers cannot play raw RTSP directly. Keep the RTSP URL server-side, then expose
# the camera through Frigate, Home Assistant, or the Lorex NVR as HTTP/MJPEG/HLS.
LOREX_CAMERA_NAME="Lorex Driveway Camera"
LOREX_CAMERA_FEED_TYPE="mjpeg"
LOREX_CAMERA_FEED_URL="http://homeassistant.local:8123/api/camera_proxy_stream/camera.lorex_driveway"
LOREX_CAMERA_SNAPSHOT_URL="http://homeassistant.local:8123/api/camera_proxy/camera.lorex_driveway"
LOREX_RTSP_URL="rtsp://username:password@192.168.1.10:554/cam/realmonitor?channel=1"
